# TaskApp Backend — environment variables
#
# IMPORTANT: app/__init__.py reads these INDIVIDUAL DATABASE_* vars (not a single
# DATABASE_URL) and SECRET_KEY. The old example listed DATABASE_URL / JWT_SECRET,
# which the app never reads — corrected here.

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Database (assembled into a postgresql:// URI in app/__init__.py)
# In Docker Compose, DATABASE_HOST is the Postgres SERVICE NAME (e.g. "postgres"),
# not localhost — containers reach each other by service name (slide 24).
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=taskapp
DATABASE_USER=taskapp_user
DATABASE_PASSWORD=taskapp_password

# Security — Flask SECRET_KEY, used to sign JWTs (see app/auth.py).
# Generate a real one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# CORS allowlist — comma-separated web origins allowed to call /api from a browser.
# Leave as * for local dev; in production set to your frontend origin, e.g.
#   CORS_ORIGINS=https://devops-tsacademy.com
CORS_ORIGINS=*
